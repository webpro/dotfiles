# Linux-specific environment overrides

# Use nano as default editor on headless servers (no VSCode)
export EDITOR="nano"
export VISUAL="nano"

# Linuxbrew — official recommended path setup (https://docs.brew.sh/Homebrew-on-Linux)
test -d /home/linuxbrew/.linuxbrew && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)" || true
