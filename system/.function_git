git_c() {
  local url="$1"
  [[ "$url" =~ ^[^:]+/.+$ ]] && url="git@github.com:${url}.git"
  local shallow=()
  [[ "${FUNCNAME[1]}" == "git_cs" ]] && shallow=(--depth 1 --single-branch)
  local dir="${url##*/}"
  dir="${dir%.git}"
  [[ -n "$2" && "$2" != -* ]] && dir="$2"
  command git clone "${shallow[@]}" "$url" "${@:2}" && cd "$dir"
}

git_cs() { git_c "$@"; }

function git() {
  case "$1" in
    c|cs)        "git_$1" "${@:2}" ;;
    *)           command git "$@" ;;
  esac
}
